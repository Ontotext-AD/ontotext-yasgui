{
  "name": "conformance-tests",
  "version": "1.0.0",
  "description": "W3C SPARQL conformance tests",
  "scripts": {
    "test": "jest --verbose",
    "test:legacy": "npx ts-node src/syntax-check.ts src"
  },
  "jest": {
    "preset": "ts-jest",
    "setupFilesAfterEnv": [
      "jest-expect-message"
    ],
    "testMatch": [
      "**/src/tests/*.spec.ts"
    ],
    "testTimeout": 60000
  },
  "dependencies": {
    "shared-conformance-utils": "file:../shared-conformance-utils"
  },
  "devDependencies": {
    "@types/codemirror": "^5.60.17",
    "@types/jest": "^29.5.14",
    "@types/node": "^16.18.126",
    "codemirror": "^5.51.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-expect-message": "^1.1.3",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "typescript": "~5.4.5"
  }
}
