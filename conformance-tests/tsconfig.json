{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": true,
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "src",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "shared-conformance-utils": ["../shared-conformance-utils/dist/index"]
    },
    "types": ["jest", "node"]
  },
  "files": ["node_modules/jest-expect-message/types/index.d.ts"],
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/grammar-build"]
}

